BOT_TOKEN=123456789:telegram-bot-token
ADMIN_CHAT_ID=123456789
TG_API_ID=12345678
TG_API_HASH=your_telegram_api_hash
TG_PHONE=+79999999999
TG_SESSION_NAME=ai_news_digest
# Optional for VPS/cloud deploy: avoids sqlite session locks.
# TG_SESSION_STRING=your_telethon_string_session
# Set false for GitHub Actions scheduled sender mode.
INTERACTIVE_BOT=true
TIMEZONE=Europe/Moscow
MORNING_HOUR=9
EVENING_HOUR=19
DB_PATH=data/digest.db
MEDIA_DIR=data/media
SOURCES_PATH=config/default_sources.yaml
MAX_IMAGES_PER_DIGEST=10
DEFAULT_DIGEST_PARAGRAPHS=5

# РЕКОМЕНДУЕТСЯ: бесплатный Gemini (лучшее качество русского языка)
# 1. Получи API-ключ бесплатно: https://aistudio.google.com/apikey
# 2. Раскомментируй строки ниже и вставь ключ:
# LLM_BACKEND=gemini
# GEMINI_API_KEY=AIza...твой_ключ_здесь
# GEMINI_MODEL=gemini-2.0-flash

# Опционально: бесплатный режим через OpenRouter (более слабое качество)
# LLM_BACKEND=openrouter
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_MODEL=openai/gpt-oss-120b:free
# LLM_FALLBACK_MODELS=arcee-ai/trinity-large-preview:free,stepfun/step-3.5-flash:free

# Опционально: платный OpenAI (качественно, но платно)
# LLM_BACKEND=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4.1-mini

# По умолчанию (без API): шаблонный дайджест без ИИ
LLM_BACKEND=none
