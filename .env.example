BOT_TOKEN=123456789:telegram-bot-token
ADMIN_CHAT_ID=123456789
TG_API_ID=12345678
TG_API_HASH=your_telegram_api_hash
TG_PHONE=+79999999999
TG_SESSION_NAME=ai_news_digest
# Optional for VPS/cloud deploy: avoids sqlite session locks.
# TG_SESSION_STRING=your_telethon_string_session
# Set false for GitHub Actions scheduled sender mode.
INTERACTIVE_BOT=true
TIMEZONE=Europe/Moscow
MORNING_HOUR=9
EVENING_HOUR=19
DB_PATH=data/digest.db
MEDIA_DIR=data/media
SOURCES_PATH=config/default_sources.yaml
MAX_IMAGES_PER_DIGEST=10
DEFAULT_DIGEST_PARAGRAPHS=5

# Default: fully local free mode with no LLM API.
LLM_BACKEND=none

# Optional free LLM mode via OpenRouter.
# LLM_BACKEND=openrouter
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_MODEL=stepfun/step-3.5-flash:free
# LLM_FALLBACK_MODELS=openrouter/free,arcee-ai/trinity-large-preview:free

# Example free setup:
# LLM_BACKEND=openrouter
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_MODEL=stepfun/step-3.5-flash:free

# Optional generic OpenAI-compatible mode.
# LLM_BACKEND=compat
# LLM_API_KEY=...
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL=stepfun/step-3.5-flash:free

# Optional paid OpenAI mode. Leave empty if not needed.
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4.1-mini
